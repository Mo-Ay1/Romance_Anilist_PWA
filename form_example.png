def get_connection() -> sqlite3.Connection:
    con = sqlite3.connect(DATABASE_PATH)
    con.row_factory = sqlite3.Row
    return con



def init_db() -> None:
    DATABASE_PATH.parent.mkdir(parents=True, exist_ok=True)
    with get_connection() as con:
        con.executescript(SCHEMA_PATH.read_text(encoding='utf-8'))
        anime_count = con.execute('SELECT COUNT(*) FROM anime').fetchone()[0]
        faq_count = con.execute('SELECT COUNT(*) FROM faq').fetchone()[0]

        if anime_count == 0:
            con.executemany(
                '''
                INSERT INTO anime (
                    slug, title, genre, watch_season, tone,
                    format, year_label, poster_path, short_blurb, synopsis
                ) VALUES (
                    :slug, :title, :genre, :watch_season, :tone,
                    :format, :year_label, :poster_path, :short_blurb, :synopsis
                )
                ''',
                SEED_ANIME,
            )

        if faq_count == 0:
            con.executemany(
                'INSERT INTO faq (question, answer) VALUES (:question, :answer)',
                SEED_FAQS,
            )



def get_featured_anime(limit: int = 4):
    with get_connection() as con:
        rows = con.execute(
            'SELECT * FROM anime ORDER BY id ASC LIMIT ?',
            (limit,),
        ).fetchall()
    return rows



def get_unique_values(column_name: str):
    allowed = {'genre', 'watch_season'}
    if column_name not in allowed:
        raise ValueError('Unsupported column name.')

    with get_connection() as con:
        rows = con.execute(
            f'SELECT DISTINCT {column_name} FROM anime ORDER BY {column_name} ASC'
        ).fetchall()
    return [row[0] for row in rows]



def search_anime(query: str = '', genre: str = '', season: str = ''):
    sql = 'SELECT * FROM anime WHERE 1=1'
    params = []

    if query:
        sql += ' AND (title LIKE ? OR short_blurb LIKE ? OR synopsis LIKE ?)'
        like_query = f'%{query}%'
        params.extend([like_query, like_query, like_query])

    if genre:
        sql += ' AND genre = ?'
        params.append(genre)

    if season:
        sql += ' AND watch_season = ?'
        params.append(season)

    sql += ' ORDER BY title COLLATE NOCASE ASC'

    with get_connection() as con:
        rows = con.execute(sql, params).fetchall()
    return rows



def get_anime_by_slug(slug: str):
    with get_connection() as con:
        row = con.execute('SELECT * FROM anime WHERE slug = ?', (slug,)).fetchone()
    return row



def get_related_anime(slug: str, genre: str, limit: int = 3):
    with get_connection() as con:
        rows = con.execute(
            '''
            SELECT * FROM anime
            WHERE slug != ? AND genre = ?
            ORDER BY title COLLATE NOCASE ASC
            LIMIT ?
            ''',
            (slug, genre, limit),
        ).fetchall()
    return rows



def get_faqs():
    with get_connection() as con:
        rows = con.execute('SELECT * FROM faq ORDER BY id ASC').fetchall()
    return rows
