const storageKey = 'romance-anilist-favourites';

function getSavedSlugs() {
    try {
        const raw = window.localStorage.getItem(storageKey);
        return raw ? JSON.parse(raw) : [];
    } catch (_error) {
        return [];
    }
}

function setSavedSlugs(slugs) {
    window.localStorage.setItem(storageKey, JSON.stringify(slugs));
}

function syncSaveButtons() {
    const saved = new Set(getSavedSlugs());
    document.querySelectorAll('[data-save-slug]').forEach((button) => {
        const slug = button.getAttribute('data-save-slug');
        const isSaved = saved.has(slug);
        button.classList.toggle('is-saved', isSaved);
        button.textContent = isSaved ? '♥ Saved' : '♡ Save';
        button.setAttribute('aria-pressed', String(isSaved));
    });
}

function setupSaveButtons() {
    document.querySelectorAll('[data-save-slug]').forEach((button) => {
        button.addEventListener('click', () => {
            const slug = button.getAttribute('data-save-slug');
            const saved = new Set(getSavedSlugs());
            if (saved.has(slug)) {
                saved.delete(slug);
            } else {
                saved.add(slug);
            }
            setSavedSlugs([...saved]);
            syncSaveButtons();
        });
    });
}

if ('serviceWorker' in navigator) {
    window.addEventListener('load', () => {
        navigator.serviceWorker
            .register('/static/js/serviceworker.js')
            .catch((error) => {
                console.log('Service worker registration failed:', error);
            });
    });
}

document.addEventListener('DOMContentLoaded', () => {
    setupSaveButtons();
    syncSaveButtons();
});
